[mysqld]
innodb_buffer_pool_size     = 256M
innodb_buffer_pool_instances = 1
innodb_log_file_size        = 64M
innodb_flush_log_at_trx_commit = 2
innodb_flush_method         = O_DIRECT
query_cache_size            = 0
query_cache_type            = 0
slow_query_log              = 1
long_query_time             = 2
skip_name_resolve
